{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Ai": {
    "UseMock": true
  },
  "MarketAgent": {
    "MaxParallelStages": 4
  },
  "SignalR": {
    "BaseUrl": "https://localhost:7296/hubs/signalpulse"
  },
  "AlphaVantage": {
    "BaseAddress": "https://www.alphavantage.co",
    "ApiKey": "VLCTZ0Q9ZTWDTMNL",
    "QuoteSymbols": [ "AAPL", "MSFT", "GOOGL", "BTCUSD", "IBM" ],
    "ForexSymbols": [ "EUR", "USD", "GBP", "JPY", "CHF" ],
    "UseLive": false
  },
  "AlphaVantageSimulation": {
    "EnableSimulation": true,
    "Volatility": 0.01,
    "MaxVolumeJitterPercent": 0.10
  },
  "Polling": {
    "Interval": "00:00:15",
    "Jitter": "00:00:02"
  },
  "AgentDebug": {
    "Enabled": false,
    "DelayMs": 500
  },
  "Postgres": {
    "ConnectionString": "Host=postgres;Port=5432;Database=signalpulsedb;Username=postgres;Password=postgres"
  },
  "Redis": {
    "Connection": "redis:6379"
  },
  "RabbitMq": {
    "MqConnection": "amqp://pulse:pulse@rabbitmq:5672",
    "Exchange": "marketdata"
  },
  "Elastic": {
    "Url": "http://elastic:9200",
    "IndexPrefix": "market-agent-events",
    "Username": "elastic", // optional
    "Password": "changeme", // optional
    "AutoRegisterTemplate": true,
    "IngestPipeline": null // optional, set if using an ingest pipeline
  },
  "Idempotency": {
    "EntryTtl": "24:00:00",
    "KeyPrefix": "idem:cmd:"
  },
  "Wolverine": {
    "Options": {
      "Endpoint": "tcp://0.0.0.0:6000"
    }
  }
}
